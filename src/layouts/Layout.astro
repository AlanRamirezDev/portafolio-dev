---
import '../styles/global.css';
import { getLangFromUrl } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portafolio Profesional" } = Astro.props;
const lang = getLangFromUrl(Astro.url);

const textosFooter = {
  es: {
    credito: "Diseñado y desarrollado por Alan Ramírez",
    codigoHub: "Código del Hub",
    docsHub: "Arquitectura del Hub",
    docsUrl: "https://alan-ramirez-dev.mintlify.site/hub/introduccion"
  },
  en: {
    credito: "Designed & developed by Alan Ramírez",
    codigoHub: "Hub Source Code",
    docsHub: "Hub Architecture",
    docsUrl: "https://alan-ramirez-dev.mintlify.site/en/hub/introduccion"
  }
};

const f = textosFooter[lang];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;700&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <title>{title}</title>
  </head>
  <body class="bg-background text-text font-sans antialiased min-h-screen selection:bg-accent/30 selection:text-accent flex flex-col">
    
    <div class="max-w-4xl w-full mx-auto px-6 flex-1">
      <slot />
    </div>

    <footer class="max-w-4xl w-full mx-auto px-6 mt-16 py-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs font-mono text-gray-500">
      <div>
        <p>{f.credito} &copy;</p>
      </div>
      
      <div class="flex items-center gap-4 flex-wrap justify-center">
        <a 
          href="https://github.com/AlanRamirezDev/portafolio-dev" 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center gap-1.5 hover:text-accent transition-colors duration-250"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
          </svg>
          {f.codigoHub}
        </a>
        
        <span class="text-white/10 hidden sm:inline">|</span>
        
        <a 
          href={f.docsUrl} 
          target="_blank" 
          rel="noopener noreferrer" 
          class="flex items-center gap-1.5 hover:text-accent transition-colors duration-250"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
          {f.docsHub}
        </a>
      </div>
    </footer>

  </body>
</html>