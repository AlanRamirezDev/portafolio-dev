---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import HeroDual from '../components/hub/HeroDual.jsx';
import TechMatrix from '../components/hub/TechMatrix.jsx';
import ExperienceTimeline from '../components/hub/ExperienceTimeline.jsx';

const ordenProyectos = [
    'motor-inversiones',
    'api-reporteria',
    'logiflow-etl',
    'iam-dashboard'
];

const proyectos = (await getCollection('proyectos')).sort((a, b) => {
    const indexA = ordenProyectos.indexOf(a.id);
    const indexB = ordenProyectos.indexOf(b.id);

    const pesoA = indexA === -1 ? 999 : indexA;
    const pesoB = indexB === -1 ? 999 : indexB;

    return pesoA - pesoB;
});
---

<Layout>
    {/* Componente Dual */}
    <HeroDual client:load />

    {/* Contenedor principal */}
    <main class="w-full max-w-4xl mx-auto px-5 md:px-8 py-8 mt-4">
        
        {/* Matriz de Tecnologías */}
        <TechMatrix client:load />

        {/* Sección de Casos de Estudio */}
        <section class="mt-8">
            <h2 class="text-2xl font-semibold mb-8 border-b border-white/10 pb-4 text-white flex items-center gap-2">
                <span class="text-accent font-mono text-lg">02.</span> Casos de Estudio
            </h2>
            
            <div class="grid gap-8">
                {proyectos.map((proyecto) => (
                    <a href={`/proyectos/${proyecto.id}`} class="block group w-full" aria-label={`Ver caso de estudio: ${proyecto.data.title}`}>
                        <article class="bg-surface p-6 md:p-8 rounded-2xl border border-white/5 group-hover:border-accent/50 transition-all duration-300 shadow-lg group-hover:shadow-[0_0_30px_rgba(99,102,241,0.3)] h-full relative overflow-hidden w-full group-hover:scale-[1.02]">
                            <div class="absolute inset-0 bg-gradient-to-r from-accent/0 via-accent/5 to-accent/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000"></div>
                            
                            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4 mb-4 relative z-10">
                                <h3 class="text-2xl font-bold text-white font-sans group-hover:text-accent transition-colors leading-tight">
                                    {proyecto.data.title}
                                </h3>
                                <span class="bg-accent/10 text-accent font-mono text-xs px-3 py-1 rounded-full border border-accent/20 shrink-0 mt-1 sm:mt-0 inline-block w-fit">
                                    {proyecto.data.status}
                                </span>
                            </div>
                            
                            <p class="text-text mb-6 leading-relaxed text-base md:text-lg relative z-10">
                                {proyecto.data.description}
                            </p>
                            
                            <div class="flex flex-wrap gap-2 relative z-10">
                                {proyecto.data.tech.map((tecnologia) => (
                                    <span class="bg-background text-gray-300 font-mono text-xs md:text-sm px-3 py-1.5 rounded-lg border border-white/10">
                                        {tecnologia}
                                    </span>
                                ))}
                            </div>
                        </article>
                    </a>
                ))}
            </div>
        </section>

        {/* Línea de Tiempo de Experiencia */}
        <ExperienceTimeline client:load />

    </main>
</Layout>