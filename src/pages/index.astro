---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const proyectos = await getCollection('proyectos');
---

<Layout>
	<main class="max-w-4xl mx-auto p-8 mt-12">
		<header class="mb-20">
			<h1 class="text-5xl font-bold mb-4 text-emerald-400">Software Engineer</h1>
			<p class="text-xl text-slate-300">
				Especializado en Arquitecturas Backend, Sistemas Distribuidos y APIs Seguras.
			</p>
		</header>

		<section>
			<h2 class="text-3xl font-semibold mb-8 border-b border-slate-700 pb-2">Casos de Estudio</h2>
			
			<div class="grid gap-8">
				{proyectos.map((proyecto) => (
					<a href={`/proyectos/${proyecto.id}`} class="block group">
						<article class="bg-slate-800 p-8 rounded-2xl border border-slate-700 group-hover:border-emerald-500 transition-colors shadow-lg h-full">
							<div class="flex justify-between items-start mb-4">
								<h3 class="text-2xl font-bold text-white">{proyecto.data.title}</h3>
								<span class="bg-emerald-900/50 text-emerald-400 text-xs px-3 py-1 rounded-full border border-emerald-700/50">
									{proyecto.data.status}
								</span>
							</div>
							
							<p class="text-slate-300 mb-6 leading-relaxed text-lg">
								{proyecto.data.description}
							</p>
							
							<div class="flex flex-wrap gap-3">
								{proyecto.data.tech.map((tecnologia) => (
									<span class="bg-slate-900 text-slate-300 text-sm px-4 py-1.5 rounded-lg border border-slate-700">
										{tecnologia}
									</span>
								))}
							</div>
						</article>
					</a>
				))}
			</div>
		</section>
	</main>
</Layout>