---
import Layout from '../layouts/Layout.astro';
import SimuladorInversiones from '../components/SimuladorInversiones.jsx';
---

<Layout title="Sandbox Transaccional | Portafolio">
  <main class="max-w-4xl mx-auto p-8 mt-4">
    <a href="/" class="text-accent hover:text-accent/80 mb-8 inline-flex items-center gap-2 font-mono text-sm transition-colors">
      <span>&lt;-</span> Volver al inicio
    </a>

    <header class="mb-12 border-b border-white/10 pb-8">
      <div class="inline-block mb-4 px-3 py-1 bg-surface border border-white/10 rounded-md">
        <code class="font-mono text-sm text-accent">
          > live_environment === "active"
        </code>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 font-sans tracking-tight">
        Motor Transaccional
      </h1>
      <p class="text-xl text-text leading-relaxed max-w-3xl">
        Esta es una demostración en vivo. El frontend en Astro/React está consumiendo directamente la API construida en Java Spring Boot para gestionar el portafolio en tiempo real.
      </p>
    </header>

    <SimuladorInversiones client:load />

  </main>
</Layout>