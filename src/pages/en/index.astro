---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import HeroDual from '../../components/hub/HeroDual.jsx';
import TechMatrix from '../../components/hub/TechMatrix.jsx';
import ExperienceTimeline from '../../components/hub/ExperienceTimeline.jsx';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const textosUI = {
    es: { 
        casos: 'Casos de Estudio',
        verCodigo: 'Ver Código en GitHub'
    },
    en: { 
        casos: 'Case Studies',
        verCodigo: 'View Code on GitHub'
    }
};
const t = textosUI[lang];

const ordenProyectos = [
    'motor-inversiones',
    'api-reporteria',
    'logiflow-etl',
    'iam-dashboard'
];

const todosLosProyectos = await getCollection('proyectos');
const proyectos = todosLosProyectos
    .filter((proyecto) => /^en[\/\\]/i.test(proyecto.id))
    .sort((a, b) => {
        const cleanA = a.id.replace(/^en[\/\\]/i, '');
        const cleanB = b.id.replace(/^en[\/\\]/i, '');
        
        const indexA = ordenProyectos.indexOf(cleanA);
        const indexB = ordenProyectos.indexOf(cleanB);
        return (indexA === -1 ? 999 : indexA) - (indexB === -1 ? 999 : indexB);
    });

const getProjectUrl = (id) => {
    const cleanId = id.replace(/^en[\/\\]/i, '');
    return `/en/proyectos/${cleanId}`;
};
---

<Layout>
    {/* Componente Dual */}
    <HeroDual client:load lang={lang} />

    {/* Contenedor principal */}
    <main class="w-full max-w-4xl mx-auto px-5 md:px-8 py-8 mt-4">
        
        {/* Matriz de Tecnologías */}
        <TechMatrix client:load lang={lang} />

        {/* Sección de Casos de Estudio */}
        <section class="mt-8">
            <h2 class="text-2xl font-semibold mb-8 border-b border-white/10 pb-4 text-white flex items-center gap-2">
                <span class="text-accent font-mono text-lg">02.</span> {t.casos}
            </h2>
            
            <div class="grid gap-8">
                {proyectos.map((proyecto) => (
                    <article class="relative bg-surface p-6 md:p-8 rounded-2xl border border-white/5 hover:border-accent/50 transition-all duration-300 shadow-lg hover:shadow-[0_0_30px_rgba(0,128,255,0.15)] h-full overflow-hidden w-full group hover:scale-[1.02]">

                        <a href={getProjectUrl(proyecto.id)} class="absolute inset-0 z-0" aria-label={lang === 'es' ? `Ver caso de estudio: ${proyecto.data.title}` : `View case study: ${proyecto.data.title}`}></a>
                        
                        <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4 mb-4 relative z-10 pointer-events-none">
                            <h3 class="text-2xl font-bold text-white font-sans group-hover:text-accent transition-colors leading-tight">
                                {proyecto.data.title}
                            </h3>
                            <span class="bg-accent/10 text-accent font-mono text-xs px-3 py-1 rounded-full border border-accent/20 shrink-0 mt-1 sm:mt-0 inline-block w-fit">
                                {proyecto.data.status}
                            </span>
                        </div>
                        
                        <p class="text-text mb-6 leading-relaxed text-base md:text-lg relative z-10 pointer-events-none">
                            {proyecto.data.description}
                        </p>
                        
                        <div class="flex flex-wrap items-center justify-between gap-6 relative z-10 pointer-events-none">
                            
                            <div class="flex flex-wrap gap-2 pointer-events-none">
                                {proyecto.data.tech.map((tecnologia) => (
                                    <span class="bg-background text-gray-300 font-mono text-xs md:text-sm px-3 py-1.5 rounded-lg border border-white/10">
                                        {tecnologia}
                                    </span>
                                ))}
                            </div>

                            {proyecto.data.githubUrl && (
                                <a 
                                    href={proyecto.data.githubUrl} 
                                    target="_blank" 
                                    rel="noopener noreferrer"
                                    class="flex items-center gap-2 bg-surface font-mono text-sm px-4 py-2 rounded-lg border border-white/10 hover:border-accent/50 transition-all duration-300 shadow-sm group/btn z-20 pointer-events-auto"
                                    aria-label={`${t.verCodigo} de ${proyecto.data.title}`}
                                >
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400 group-hover/btn:text-accent transition-colors">
                                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.02c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                                    </svg>
                                    <span class="text-gray-300 group-hover/btn:text-accent transition-colors tracking-tight">{t.verCodigo}</span>
                                </a>
                            )}
                        </div>
                    </article>
                ))}
            </div>
        </section>

        {/* Línea de Tiempo de Experiencia */}
        <ExperienceTimeline client:load lang={lang} />

    </main>
</Layout>