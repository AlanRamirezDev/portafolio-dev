---
import Layout from '../../../layouts/Layout.astro';
import InversionesDashboard from '../../../components/transaccional/InversionesDashboard.jsx';
import { getLangFromUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const ui = {
    es: {
        titleTag: "Motor Transaccional | Portafolio",
        backLink: "Volver al inicio",
        backUrl: "/",
        h1: "Motor Transaccional",
        description: "Esta es una demostración en vivo. El frontend en Astro/React está consumiendo directamente la API construida en Java Spring Boot para gestionar el portafolio en tiempo real."
    },
    en: {
        titleTag: "Transactional Engine | Portfolio",
        backLink: "Back to home",
        backUrl: "/en/",
        h1: "Transactional Engine",
        description: "This is a live demonstration. The Astro/React frontend is directly consuming the API built in Java Spring Boot to manage the portfolio in real time."
    }
};

const t = ui[lang] || ui['es'];
---

<Layout title={t.titleTag}>
  <main class="max-w-4xl mx-auto p-8 mt-4">
    <a href={t.backUrl} id="back-home-link" class="text-accent hover:text-accent/80 mb-8 inline-flex items-center gap-2 font-mono text-sm transition-colors">
      <span aria-hidden="true">&lt;-</span> {t.backLink}
    </a>

    <header class="mb-12 border-b border-white/10 pb-8">
      <div class="inline-block mb-4 px-3 py-1 bg-surface border border-white/10 rounded-md">
        <code class="font-mono text-sm text-accent">
          > live_environment === "active"
        </code>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 font-sans tracking-tight">
        {t.h1}
      </h1>
      <p class="text-xl text-text leading-relaxed max-w-3xl">
        {t.description}
      </p>
    </header>

    <InversionesDashboard client:load lang={lang} />

  </main>

  <script>
    window.addEventListener('transaccional-action', (e) => {
        const event = e as CustomEvent;
        const isProcessing = event.detail?.active;
        const backLink = document.getElementById('back-home-link');

        if (isProcessing) {
            backLink?.classList.add('opacity-50', 'pointer-events-none');
        } else {
            backLink?.classList.remove('opacity-50', 'pointer-events-none');
        }
    });
  </script>
</Layout>