---
import Layout from '../../../layouts/Layout.astro';
import LogiflowDashboard from '../../../components/logiflow/LogiflowDashboard.jsx';
import { getLangFromUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const ui = {
    es: {
        titleTag: "Pipeline ETL | Portafolio",
        backLink: "Volver al inicio",
        backUrl: "/",
        h1: "Pipeline ETL Asíncrono",
        description: "Esta es una demostración en vivo. El frontend en Astro/React se comunica con la API construida en Java Spring Boot para delegar el procesamiento masivo de datos mediante hilos virtuales."
    },
    en: {
        titleTag: "ETL Pipeline | Portfolio",
        backLink: "Back to home",
        backUrl: "/en/",
        h1: "Asynchronous ETL Pipeline",
        description: "This is a live demonstration. The Astro/React frontend communicates with the API built in Java Spring Boot to delegate massive data processing using virtual threads."
    }
};

const t = ui[lang] || ui['es'];
---

<Layout title={t.titleTag}>
  <main class="max-w-4xl mx-auto p-8 mt-4">
    <a href={t.backUrl} class="text-accent hover:text-accent/80 mb-8 inline-flex items-center gap-2 font-mono text-sm transition-colors">
      <span>&lt;-</span> {t.backLink}
    </a>

    <header class="mb-10 border-b border-white/10 pb-8">
      <div class="inline-block mb-4 px-3 py-1 bg-surface border border-white/10 rounded-md">
        <code class="font-mono text-sm text-accent">
          > batch_processing === "async"
        </code>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 font-sans tracking-tight">
        {t.h1}
      </h1>
      <p class="text-xl text-text leading-relaxed max-w-3xl mb-6">
        {t.description}
      </p>
    </header>

    <LogiflowDashboard client:load lang={lang} />

  </main>
</Layout>