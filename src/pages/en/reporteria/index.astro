---
import Layout from '../../../layouts/Layout.astro';
import ReporteriaDashboard from '../../../components/reporteria/ReporteriaDashboard.jsx';
import { getLangFromUrl } from '../../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const ui = {
    es: {
        titleTag: "Generador de Reportes",
        back: "Volver al inicio",
        title: "Generador Dinámico de Reportes",
        description: "Demostración de generación de archivos binarios en tiempo real. El frontend en Astro/React empaqueta cargas estructuradas en JSON y las transmite hacia un microservicio aislado en Laravel para su procesamiento en memoria."
    },
    en: {
        titleTag: "Report Generator",
        back: "Back to home",
        title: "Dynamic Report Generator",
        description: "Real-time binary file generation demonstration. The Astro/React frontend packages structured JSON payloads and transmits them to an isolated Laravel microservice for in-memory processing."
    }
};

const t = ui[lang] || ui['es'];
const homeUrl = lang === 'es' ? '/' : '/en/';
---

<Layout title={`${t.titleTag} | Portafolio`}>
  <main class="max-w-4xl mx-auto p-8 mt-4">
    
    <a href={homeUrl} id="back-home-link" class="text-accent hover:text-accent/80 mb-8 inline-flex items-center gap-2 font-mono text-sm transition-colors">
      <span aria-hidden="true">&lt;-</span> {t.back}
    </a>

    <header class="mb-12 border-b border-white/10 pb-8">
      <div class="inline-block mb-4 px-3 py-1 bg-surface border border-white/10 rounded-md">
        <code class="font-mono text-sm text-accent">
          > core_service === "stateless_reporter"
        </code>
      </div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 font-sans tracking-tight">
        {t.title}
      </h1>
      <p class="text-xl text-text leading-relaxed max-w-3xl">
        {t.description}
      </p>
    </header>

    <ReporteriaDashboard client:load lang={lang} />

  </main>

  <script>
    window.addEventListener('reporteria-action', (e) => {
        const customEvent = e as CustomEvent;
        const isProcessing = customEvent.detail?.active;
        const backLink = document.getElementById('back-home-link');

        if (isProcessing) {
            backLink?.classList.add('opacity-50', 'pointer-events-none');
        } else {
            backLink?.classList.remove('opacity-50', 'pointer-events-none');
        }
    });
  </script>
</Layout>