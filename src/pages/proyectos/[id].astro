---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// 1. Función para saber cuántas páginas generar (una por cada archivo .md)
export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map(proyecto => ({
    params: { id: proyecto.id },
    props: { proyecto },
  }));
}

// 2. Obtenemos los datos del proyecto actual
const { proyecto } = Astro.props;
// 3. Extraemos el contenido HTML que se generó desde el Markdown
const { Content } = await render(proyecto);
---

<Layout>
  <main class="max-w-3xl mx-auto p-8 mt-12">
    <a href="/" class="text-emerald-400 hover:text-emerald-300 mb-8 inline-block font-semibold transition-colors">
      &larr; Volver al inicio
    </a>

    <header class="mb-12 border-b border-slate-700 pb-8">
      <h1 class="text-4xl font-bold text-white mb-4">{proyecto.data.title}</h1>
      <div class="flex gap-3 mb-6">
        {proyecto.data.tech.map((tecnologia) => (
          <span class="bg-slate-800 text-emerald-400 text-sm px-3 py-1 rounded border border-slate-700">
            {tecnologia}
          </span>
        ))}
      </div>
      <p class="text-xl text-slate-300 leading-relaxed">{proyecto.data.description}</p>
    </header>

    <article class="prose prose-invert prose-emerald lg:prose-lg max-w-none">
      <Content />
    </article>
  </main>
</Layout>