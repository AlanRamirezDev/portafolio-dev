---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// Función para saber cuántas páginas generar (una por cada archivo .md)
export async function getStaticPaths() {
  const proyectos = await getCollection('proyectos');
  return proyectos.map(proyecto => ({
    params: { id: proyecto.id },
    props: { proyecto },
  }));
}

// Obtenemos los datos del proyecto actual
const { proyecto } = Astro.props;
const { Content } = await render(proyecto);
---

<Layout title={`${proyecto.data.title} | Portafolio Backend`}>
  <main class="max-w-4xl mx-auto p-8 mt-4">
    <a href="/" class="text-accent hover:text-accent/80 mb-8 inline-flex items-center gap-2 font-mono text-sm transition-colors">
      <span>&lt;-</span> Volver al sistema principal
    </a>

    <header class="mb-12 border-b border-white/10 pb-8">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-6 font-sans tracking-tight">
        {proyecto.data.title}
      </h1>
      
      <div class="flex flex-wrap gap-3 mb-6">
        {proyecto.data.tech.map((tecnologia) => (
          <span class="bg-surface text-accent font-mono text-sm px-3 py-1 rounded-md border border-white/10 shadow-sm">
            {tecnologia}
          </span>
        ))}
      </div>
      
      <p class="text-xl text-text leading-relaxed max-w-3xl mb-6">
        {proyecto.data.description}
      </p>

      {proyecto.id === 'motor-inversiones' && (
        <div class="mb-4">
          <a href="/transaccional" class="inline-flex items-center gap-2 bg-accent text-background font-bold px-4 py-2 rounded-lg hover:bg-accent/80 transition-colors shadow-sm text-sm">
            🚀 Probar Motor en Vivo
          </a>
        </div>
      )}

      {proyecto.id === 'iam-dashboard' && (
        <div class="mb-4">
          <a href="/iam" class="inline-flex items-center gap-2 bg-accent text-background font-bold px-4 py-2 rounded-lg hover:bg-accent/80 transition-colors shadow-sm text-sm">
            🛡️ Probar Panel IAM en Vivo
          </a>
        </div>
      )}

      {proyecto.id === 'logiflow-etl' && (
        <div class="mb-4">
          <a href="/logiflow" class="inline-flex items-center gap-2 bg-accent text-background font-bold px-4 py-2 rounded-lg hover:bg-accent/80 transition-colors shadow-sm text-sm">
            ⚡ Probar Pipeline ETL en Vivo
          </a>
        </div>
      )}

      {proyecto.id === 'api-reporteria' && (
        <div class="mb-4">
          <a href="/reporteria" class="inline-flex items-center gap-2 bg-accent text-background font-bold px-4 py-2 rounded-lg hover:bg-accent/80 transition-colors shadow-sm text-sm">
            📄 Probar Generador en Vivo
          </a>
        </div>
      )}
    </header>

    <article class="prose prose-invert prose-headings:font-sans prose-headings:text-white prose-p:text-text prose-a:text-accent hover:prose-a:text-accent/80 prose-code:font-mono prose-code:text-accent prose-pre:bg-surface prose-pre:border prose-pre:border-white/10 max-w-none">
      <Content />
    </article>
  </main>
</Layout>