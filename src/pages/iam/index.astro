---
import '../../styles/global.css';
import LoginForm from '../../components/iam/LoginForm.jsx';
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="theme-color" content="bg-black" />
        <title>Login - IAM Dashboard</title>
    </head>
    <body class="min-h-screen flex flex-col lg:flex-row bg-surface text-text antialiased">
        
        {/* Panel Izquierdo */}
        <main class="relative w-full lg:w-5/12 min-h-screen flex flex-col z-10">
            
            {/* Header */}
            <header class="flex items-center justify-between p-6 sm:p-10">
                <a href="/proyectos/iam-dashboard" class="flex items-center gap-2 text-white font-semibold tracking-tight hover:opacity-80 transition-opacity" title="Volver al portafolio">
                    <span class="w-8 h-8 rounded-lg bg-accent/15 border border-accent/25 flex items-center justify-center">
                        <svg aria-hidden="true" class="w-4 h-4 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                    </span>
                    <span>Volver</span>
                </a>
                <span class="hidden sm:inline text-xs text-text/50 uppercase tracking-widest">Portal Demo</span>
            </header>

            {/* Formulario */}
            <div class="flex-1 flex items-center justify-center p-6 sm:p-12">
                <div class="w-full max-w-sm">
                    <LoginForm client:only="react" />
                </div>
            </div>

            {/* Footer */}
            <footer class="p-6 sm:p-10 flex items-center justify-between text-xs text-text/50">
                <span>© 2026 AlanRamirezDev</span>
            </footer>
        </main>

        {/* Panel Derecho */}
        <aside class="hidden lg:flex lg:w-7/12 relative border-l border-white/5 overflow-hidden items-center justify-center">
            <div class="absolute inset-0 bg-gradient-to-br from-[#0b1020] via-[#0d1428] to-[#0a0f1f]"></div>
            <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.8) 1px, transparent 0); background-size: 28px 28px;"></div>
            <div class="absolute -top-1/4 -right-1/4 w-[80%] h-[80%] bg-accent/10 blur-3xl rounded-full opacity-40"></div>
            <div class="absolute -bottom-1/4 -left-1/4 w-[60%] h-[60%] bg-accent/5 blur-3xl rounded-full opacity-30"></div>

            {/* Contenido central */}
            <div class="relative z-10 px-16 max-w-2xl text-center">
                <div class="relative w-20 h-20 mx-auto mb-10">
                    <div class="absolute inset-0 rounded-2xl bg-accent/10 border border-accent/20"></div>
                    <div class="absolute inset-0 rounded-2xl bg-accent/5 blur-xl"></div>
                    <div class="relative w-full h-full flex items-center justify-center">
                        <svg aria-hidden="true" class="w-10 h-10 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
                        </svg>
                    </div>
                </div>
                
                <h2 class="text-4xl font-bold text-white tracking-tight mb-5 leading-tight">
                    Gestión de Identidades<br/>
                    <span class="text-accent">Segura y Auditable</span>
                </h2>
                <p class="text-base text-text/80 leading-relaxed mx-auto max-w-lg mb-10">
                    Sistema de Control de Accesos Basado en Roles (RBAC) con trazabilidad en tiempo real y protección contra vulnerabilidades.
                </p>

                {/* Trust indicators */}
                <div class="grid grid-cols-3 gap-6 max-w-md mx-auto pt-8 border-t border-white/5">
                    <div class="text-center">
                        <div class="text-xs text-text/50 uppercase tracking-wider mb-1">Token</div>
                        <div class="text-sm text-white font-medium">JWT Seguro</div>
                    </div>
                    <div class="text-center border-x border-white/5">
                        <div class="text-xs text-text/50 uppercase tracking-wider mb-1">Pruebas</div>
                        <div class="text-sm text-white font-medium">Pest PHP</div>
                    </div>
                    <div class="text-center">
                        <div class="text-xs text-text/50 uppercase tracking-wider mb-1">Control</div>
                        <div class="text-sm text-white font-medium">RBAC Nativo</div>
                    </div>
                </div>
            </div>

            {/* Marca de agua inferior derecha */}
            <div class="absolute bottom-6 right-8 text-[10px] uppercase tracking-[0.3em] text-white/20">
                v1.0
            </div>
        </aside>

        {/* Script de validación de sesión activa */}
        <script>
            // Si el usuario ya está autenticado lo redirige automáticamente
            if (localStorage.getItem('jwt_token')) {
                window.location.replace('/iam/dashboard');
            }
        </script>
    </body>
</html>