---
import '../../styles/global.css';
import UserManagement from '../../components/iam/UserManagement.jsx';
---

<html lang="es">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>Usuarios - IAM Dashboard</title>
    </head>
    <body class="min-h-screen bg-[#0b1020]">
        
        <nav class="bg-surface border-b border-white/5 px-4 md:px-6 py-4">
            <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-8 w-full sm:w-auto">
                    <h1 class="text-xl font-bold text-white tracking-tight text-center sm:text-left w-full sm:w-auto">IAM</h1>
                    <div class="flex justify-center gap-4 w-full sm:w-auto">
                        <a href="/iam/dashboard" id="nav-dashboard-link" class="text-sm font-medium text-text hover:text-white transition-colors">Bitácora</a>
                        <a href="/iam/users" id="nav-users-link" class="text-sm font-medium text-accent border-b border-accent pb-1">Gestión de Usuarios</a>
                    </div>
                </div>
                <button 
                    id="logout-btn"
                    class="px-4 py-2 text-sm font-medium text-red-400 bg-red-400/10 hover:bg-red-400/20 border border-red-400/20 rounded-lg transition-colors w-full sm:w-auto"
                >
                    Cerrar Sesión
                </button>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto p-6 md:p-8 space-y-6">
            <header>
                <h2 class="text-3xl font-bold text-white tracking-tight">Control de Accesos</h2>
                <p class="text-sm text-text mt-1">Asignación de roles y privilegios (RBAC).</p>
            </header>

            <UserManagement client:only="react" />
        </main>

        <script>
            import iamApi from "../../lib/iam/iamApi";

            // Expulsa al usuario antes de que intente interactuar con el DOM si no hay sesión
            if (!localStorage.getItem('jwt_token')) {
                window.location.replace('/iam');
            }

            // Listener global del estado
            window.addEventListener('iam-user-creation', (e) => {
                const isCreating = e.detail.active;
                const logoutBtn = document.getElementById('logout-btn');
                const dashboardLink = document.getElementById('nav-dashboard-link');
                const usersLink = document.getElementById('nav-users-link');

                if (isCreating) {
                    if (logoutBtn) logoutBtn.disabled = true;
                    logoutBtn?.classList.add('opacity-50', 'pointer-events-none');
                    dashboardLink?.classList.add('opacity-50', 'pointer-events-none');
                    usersLink?.classList.add('opacity-50', 'pointer-events-none');
                } else {
                    if (logoutBtn) logoutBtn.disabled = false;
                    logoutBtn?.classList.remove('opacity-50', 'pointer-events-none');
                    dashboardLink?.classList.remove('opacity-50', 'pointer-events-none');
                    usersLink?.classList.remove('opacity-50', 'pointer-events-none');
                }
            });

            // Manejo de cierre de sesión
            document.getElementById('logout-btn')?.addEventListener('click', async () => {
                const btn = document.getElementById('logout-btn');
                if (btn) {
                    btn.innerText = 'Cerrando sesión...';
                    btn.classList.add('opacity-50', 'cursor-not-allowed');
                }
                
                try {
                    await iamApi.post('/auth/logout');
                } catch (error) {
                    console.warn('La sesión ya había expirado en el servidor.');
                } finally {
                    localStorage.removeItem('jwt_token');
                    localStorage.removeItem('user');
                    window.location.replace('/iam');
                }
            });
        </script>
    </body>
</html>