---
import '../../styles/global.css';
import AuditLogsTable from '../../components/iam/AuditLogsTable.jsx';
import { getLangFromUrl } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);

const ui = {
    es: {
        titleTag: "Dashboard - IAM Bitácora",
        navLog: "Bitácora",
        navUsers: "Gestión de Usuarios",
        navLogout: "Cerrar Sesión",
        headerTitle: "Panel de Auditoría",
        headerDesc: "Bitácora de eventos de seguridad capturados en tiempo real.",
        linkDashboard: "/iam/dashboard",
        linkUsers: "/iam/users"
    },
    en: {
        titleTag: "Dashboard - IAM Audit Log",
        navLog: "Audit Log",
        navUsers: "User Management",
        navLogout: "Sign Out",
        headerTitle: "Audit Panel",
        headerDesc: "Security event log captured in real time.",
        linkDashboard: "/en/iam/dashboard",
        linkUsers: "/en/iam/users"
    }
};

const t = ui[lang] || ui['es'];
---

<html lang={lang}>
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>{t.titleTag}</title>
    </head>
    <body class="min-h-screen bg-[#0b1020]">
        
        <nav class="bg-surface border-b border-white/5 px-4 md:px-6 py-4">
            <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
                <div class="flex flex-col sm:flex-row items-center gap-3 sm:gap-8 w-full sm:w-auto">
                    <h1 class="text-xl font-bold text-white tracking-tight text-center sm:text-left w-full sm:w-auto">IAM</h1>
                    <div class="flex justify-center gap-4 w-full sm:w-auto">
                        <a href={t.linkDashboard} id="nav-dashboard-link" class="text-sm font-medium text-accent border-b border-accent pb-1">{t.navLog}</a>
                        <a href={t.linkUsers} id="nav-users-link" class="text-sm font-medium text-text hover:text-white transition-colors">{t.navUsers}</a>
                    </div>
                </div>
                <button 
                    id="logout-btn"
                    class="px-4 py-2 text-sm font-medium text-red-400 bg-red-400/10 hover:bg-red-400/20 border border-red-400/20 rounded-lg transition-colors w-full sm:w-auto"
                >
                    {t.navLogout}
                </button>
            </div>
        </nav>

        <main class="max-w-7xl mx-auto p-6 md:p-8 space-y-6">
            <header>
                <h2 class="text-3xl font-bold text-white tracking-tight">{t.headerTitle}</h2>
                <p class="text-sm text-text mt-1">{t.headerDesc}</p>
            </header>

            <AuditLogsTable client:only="react" lang={lang} />
        </main>

        <script>
            import iamApi from "../../lib/iam/iamApi";

            const isEnglish = window.location.pathname.startsWith('/en');
            const loginUrl = isEnglish ? '/en/iam' : '/iam';

            // Expulsa al usuario antes de que intente interactuar con el DOM si no hay sesión
            if (!localStorage.getItem('jwt_token')) {
                window.location.replace(loginUrl);
            }

            // Listener global del estado
            window.addEventListener('iam-simulation', (e) => {
                const event = e as CustomEvent;
                const isSimulating = event.detail?.active;
                
                const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement;
                const usersLink = document.getElementById('nav-users-link');
                const dashboardLink = document.getElementById('nav-dashboard-link');

                if (isSimulating) {
                    if (logoutBtn) logoutBtn.disabled = true;
                    logoutBtn?.classList.add('opacity-50', 'pointer-events-none');
                    usersLink?.classList.add('opacity-50', 'pointer-events-none');
                    dashboardLink?.classList.add('opacity-50', 'pointer-events-none');
                } else {
                    if (logoutBtn) logoutBtn.disabled = false;
                    logoutBtn?.classList.remove('opacity-50', 'pointer-events-none');
                    usersLink?.classList.remove('opacity-50', 'pointer-events-none');
                    dashboardLink?.classList.remove('opacity-50', 'pointer-events-none');
                }
            });

            // Manejo de cierre de sesión
            document.getElementById('logout-btn')?.addEventListener('click', async () => {
                const btn = document.getElementById('logout-btn');
                if (btn) {
                    btn.innerText = isEnglish ? 'Signing out...' : 'Cerrando sesión...';
                    btn.classList.add('opacity-50', 'cursor-not-allowed');
                }
                
                try {
                    await iamApi.post('/auth/logout');
                } catch (error) {
                    console.warn(isEnglish ? 'Session already expired on server.' : 'La sesión ya había expirado en el servidor.');
                } finally {
                    localStorage.removeItem('jwt_token');
                    localStorage.removeItem('user');
                    window.location.replace(loginUrl);
                }
            });
        </script>
    </body>
</html>